        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nsetOption(\"ExpandableArrays\", true);\n\nrun(\"Duplicate...\", \"title=Zero_thickness\");\nsetThreshold(0, 255);\nrun(\"Convert to Mask\", \"background=Dark black\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\nimageCalculator(\"Multiply create 32-bit\", \"Tissue thickness\",\"Zero_thickness\");\n\nselectWindow(\"Result of Tissue thickness\");\n// Get the 5th and 95th percentile\nwidth=getWidth();\nheight=getHeight();\n\t \t \npixel_values=newArray();\nsetOption(\"ExpandableArrays\", true);\ninc=0;\nfor (row=0; row<height; row++) {\t\n    for (col=0; col<width; col++) {\n    \tv = getPixel(col, row);\n    \tif (isNaN(v)==false) {\n    \t\tpixel_values[inc]=v;\n\t\t\tinc=inc+1;\t    \t\t\n    \t}\n\t}\n}\n//Array.show(pixel_values);\n\n// Randomly select from pixel values\nnewArraySize = 10000;\npixel_values_RandSlc = newArray(newArraySize);\nfor (i = 0; i < newArraySize; i++) {\n    randomIndex = round(random() * (pixel_values.length - 1));   \n    pixel_values_RandSlc[i] = pixel_values[randomIndex];\n}\n//Array.show(pixel_values_RandSlc);\n\nTable.create(\"Tissue architecture-Results\");\nTable.setColumn(\"Tissue thickness\", pixel_values_RandSlc);\n\nclose(\"*\");\nclose(\"Results\");\nclose(\"Log\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
