              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Tissue damage" : {
              "slot-data-type" : "imagej-imgplus-2d-greyscale-mask",
              "slot-type" : "Output",
              "name" : "Tissue damage",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "" : {
            "VerticalCompact" : {
              "x" : 11,
              "y" : 17
            }
          },
          "169aeb15-2bbc-44e4-95be-840f58c5343d" : {
            "VerticalCompact" : {
              "x" : 1,
              "y" : 12
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nrun(\"Select None\");\n\n// Maxprojection\nselectWindow(\"ZO-1\");\nrun(\"Z Project...\", \"projection=[Max Intensity]\");\nclose(\"ZO-1\");\n\n// Threshold\nselectWindow(\"MAX_ZO-1\");\nsetThreshold(prm_thrsh, 1.000E+30);\nrun(\"Convert to Mask\", \"background=Dark black\");\nrun(\"Invert\");\n\n// Exclude edges and artifacts\nimageCalculator(\"Multiply\", \"MAX_ZO-1\",\"Mask\");\n\nrun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\nsetThreshold(1, 1.000E+30, \"raw\");\nrun(\"Convert to Mask\");\n\nrun(\"Morphological Filters\", \"operation=Closing element=Square radius=prm_cls\");\nrename(\"Tissue damage\");\n\n// Results table of damage area fraction\nvalues_area_chip = newArray();\t\nvalues_area_damage = newArray();\t\nvalues_damage_fraction = newArray();\t\n\nselectWindow(\"Mask\");\nrun(\"Analyze Particles...\", \"summarize\");\nselectWindow(\"Tissue damage\");\nrun(\"Analyze Particles...\", \"summarize\");\nTable.rename(\"Summary\", \"Results\");\nvalues_area_chip[0] = getResult(\"Total Area\", 0);\t\t\nvalues_area_damage[0] = getResult(\"Total Area\", 1);\nvalues_damage_fraction[0] = getResult(\"Total Area\", 1)/getResult(\"Total Area\", 0);\nclose(\"Results\");\n\nTable.create(\"Tissue damage-Results\");\nTable.setColumn(\"Chip area\", values_area_chip);\nTable.setColumn(\"Damage area\", values_area_damage);\nTable.setColumn(\"Damage area fraction\", values_damage_fraction);\n\nsetBatchMode(\"show\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
