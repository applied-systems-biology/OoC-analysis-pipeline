      "a210347c-84bf-4b78-a255-ed61c510bd2f" : {
        "jipipe:graph-compartment" : "169aeb15-2bbc-44e4-95be-840f58c5343d",
        "jipipe:alias-id" : "epithelial-tissue-interpolation",
        "jipipe:slot-configuration" : {
          "input" : {
            "Epithelial tissue" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-16u",
              "slot-type" : "Input",
              "name" : "Epithelial tissue",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Maskout" : {
              "slot-data-type" : "imagej-imgplus-2d-greyscale-mask",
              "slot-type" : "Input",
              "name" : "Maskout",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          },
          "output" : {
            "Interpolated epithelial tissue" : {
              "slot-data-type" : "imagej-imgplus-2d-greyscale-32f",
              "slot-type" : "Output",
              "name" : "Interpolated epithelial tissue",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "169aeb15-2bbc-44e4-95be-840f58c5343d" : {
            "VerticalCompact" : {
              "x" : 20,
              "y" : 23
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\n\nselectWindow(\"Epithelial tissue\");\nrun(\"Duplicate...\", \"title=Nuclei_NaN-1\");\nrun(\"Duplicate...\", \"title=Nuclei_NaN-2\");\nrun(\"Combine...\", \"stack1=Nuclei_NaN-1 stack2=Nuclei_NaN-2\");\n\t\nselectWindow(\"Epithelial tissue\");\nwidth=getWidth();\nheight=getHeight();\nwnd_hlf=round(prm_wnd/2);\nselectWindow(\"Combined Stacks\");\nfor (row=0; row<height; row++) {\n\tinc=0;\n    for (col=0; col<width-wnd_hlf; col++) {\n    \tv = getPixel(col, row);         \n        if (isNaN(v)) {\n         \tmakeRectangle(col-wnd_hlf, row-wnd_hlf, prm_wnd, prm_wnd);\n         \tgetRawStatistics(nPixels, mean, min, max, std, histogram);\n\t\t\tsetPixel(col+width, row, round(mean));\n        }\n     }\n\t   \n    inc=0;\n    for (col=width-wnd_hlf; col<width; col++) {\n    \tv = getPixel(col, row); \n        if (isNaN(v)) {\n         \tmakeRectangle(col-wnd_hlf, row-wnd_hlf, prm_wnd-inc, prm_wnd);\n         \tgetRawStatistics(nPixels, mean, min, max, std, histogram);\n\t\t\tsetPixel(col+width, row, round(mean));\n         }\n         inc=inc+1;\n    }\t   \n}\n\nclose(\"Epithelial tissue\");\nselectWindow(\"Combined Stacks\");\nmakeRectangle(width, 0, width, height);\nrun(\"Duplicate...\", \"title=Nuclei_intrp\");\nclose(\"Combined Stacks\");\n\n//Exclude edges and artifacts\nselectWindow(\"Maskout\");\nrun(\"32-bit\");\nsetThreshold(1.000, 1.000E+30);\nrun(\"NaN Background\");\nrun(\"Replace/Remove Label(s)\", \"label(s)=255 final=1\");\n\t\nimageCalculator(\"Multiply create 32-bit stack\", \"Nuclei_intrp\",\"Maskout\");\nrename(\"Nuclei_intrp-32bit\");\n\nselectWindow(\"Nuclei_intrp-32bit\");\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\t\t\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\t\nsetBatchMode(\"show\");\nrename(\"Interpolated epithelial tissue\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
