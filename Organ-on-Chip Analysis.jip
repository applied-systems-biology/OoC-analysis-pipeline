        },
        "jipipe:ui-grid-location" : {
          "" : {
            "VerticalCompact" : {
              "x" : 17,
              "y" : 7
            }
          },
          "fb3bfe3a-c9c1-4ec4-908b-3f1b7380a851" : {
            "VerticalCompact" : {
              "x" : 11,
              "y" : 7
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\n\n// Resolution\nselectWindow(\"Microcolony\");\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\n// Exclude edges and artifacts\nselectWindow(\"Mask\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\nimageCalculator(\"Multiply stack\", \"Microcolony\",\"Mask\");\nclose(\"Mask\");\n\t\t\n// Rolling Boll Radius: find the maximum feret diameter of the largest region of interest\nselectWindow(\"Microcolony\");\t\t\nrun(\"Z Project...\", \"projection=[Max Intensity]\");\nrename(\"RBR\");\nsetAutoThreshold(\"Triangle dark stack\");\nrun(\"Make Binary\", \"method=Triangle background=Dark black\");\nrun(\"Keep Largest Region\");\t\t\nrun(\"Bounding Box\", \"label=RBR-largest image=RBR-largest\");\nTable.rename(\"RBR-largest-BBox\", \"Results\");\t\t\t\nmakeRectangle(getResult(\"Box2D.XMin\", 0)/ResXY-20, getResult(\"Box2D.YMin\", 0)/ResXY-20, (getResult(\"Box2D.XMax\", 0)-getResult(\"Box2D.XMin\", 0))/ResXY+40, (getResult(\"Box2D.YMax\", 0)-getResult(\"Box2D.YMin\", 0))/ResXY+40);\nrun(\"Crop\");\nclose(\"Results\");\nrun(\"Max. Feret Diameters\", \"label=RBR-largest image=RBR-largest\");\nTable.rename(\"RBR-largest-FeretDiams\", \"Results\");\nRBR = getResult(\"Diameter\", 0)/2;\nclose(\"RBR\");\nclose(\"RBR-largest\");\nclose(\"Results\");\n\t\t\t\n// Subtract the background and apply intensity transformation \nselectWindow(\"Microcolony\");\nrun(\"Subtract Background...\", \"rolling=\"+RBR+\" stack\");\t\t\nrun(\"Gamma...\", \"value=prm_gamma stack\");\nrename(\"Enhanced signal\");\n\n// Threshold\nrun(\"Duplicate...\", \"title=Segmentation duplicate\");\nsetAutoThreshold(\"\"+prm_thrsh+\" dark stack\");\nrun(\"Convert to Mask\", \"method=\"+prm_thrsh+\" background=Dark black\");\n\nclose(\"Results\");\nclose(\"Log\");\n\nsetBatchMode(\"show\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
