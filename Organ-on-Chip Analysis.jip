      "f8f8d7f4-00a8-4d77-b579-6d889a98ac69" : {
        "jipipe:graph-compartment" : "fb3bfe3a-c9c1-4ec4-908b-3f1b7380a851",
        "jipipe:alias-id" : "branch-reconstruction",
        "jipipe:slot-configuration" : {
          "input" : {
            "Enhanced signal" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-16u",
              "slot-type" : "Input",
              "name" : "Enhanced signal",
              "custom-name" : null,
