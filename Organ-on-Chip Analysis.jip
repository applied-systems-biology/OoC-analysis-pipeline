        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\n\n// Remove objects on border\nselectWindow(\"Microcolony\");\nrun(\"Remove Border Labels\", \"left right top bottom\");\nsetThreshold(1, 1.000E+30, \"raw\");\nrun(\"Convert to Mask\", \"background=Dark black\");\nclose(\"Microcolony\");\n\n// Downsample inputs to reduce computation time\nselectWindow(\"Microcolony-killBorders\");\nrun(\"Scale...\", \"x=0.5 y=0.5 z=1.0 interpolation=None process create title=Microcolony-killBorders-ds\");\nselectWindow(\"Vertical view\");\nrun(\"Scale...\", \"x=0.5 y=0.5 z=1.0 interpolation=None process create title=Vertical-view-ds\");\nclose(\"Vertical view\");\n\n// Microcolony volume (pix) - Epithelial compartment\nselectWindow(\"Vertical-view-ds\");\nrun(\"Duplicate...\", \"title=Epithelial_Colonies duplicate\");\nsetThreshold(101, 255);\nrun(\"Convert to Mask\", \"background=Dark black\");\nimageCalculator(\"Multiply stack\", \"Epithelial_Colonies\",\"Microcolony-killBorders-ds\");\nrun(\"3D Volume\");\nV_Epithelial_C=0;\nfor (row = 0; row < nResults(); row++) {\n    V_Epithelial_C += getResult(\"Volume(Pix)\", row);\n}\nclose(\"Epithelial_Colonies\");\nclose(\"Results\");\n\n// Tissue type area (pix)\nselectWindow(\"Vertical-view-ds\");\nsetSlice(1);\nrun(\"Duplicate...\", \"title=Area\");\nrun(\"3D Volume\");\nfor (row = 0; row < nResults(); row++) {\n\tif (getResult(\"LabelObj\", row)==200) {\n\t\tA_Low = getResult(\"Volume(Pix)\", row);\t\t\n\t}\n\tif (getResult(\"LabelObj\", row)==255) {\n\t\tA_High = getResult(\"Volume(Pix)\", row);\t\t\n\t}\n}\nA_Total = A_Low + A_High;\nclose(\"Area\");\nclose(\"Results\");\n\t\t\t\n// Microcolony interactions with tissue types\nrun(\"3D MultiColoc\", \"image_a=Vertical-view-ds image_b=Microcolony-killBorders-ds\");\nTable.rename(\"Colocalisation\", \"Results\");\n\n// Classification to 2 viesws\n// Vertical view:\tQuantification of epithelial tissue penetration and vascular invasion\n// Labels:\n// Edges: 50\n// Vascular compartment: 100\n// Low-density tissue: 200\n// High-density tissue: 255\n\n// Number of stack classes which have colocalization with objects in microcolony channel\nselectWindow(\"Vertical-view-ds\");\nStack.getStatistics(voxelCount, mean, min, max, stdDev);\nif (min==50) {\n\t//delete the edge class\n\tTable.deleteRows(0, 0);\t\n}\nN=nResults;\n\n// Tissue-based localization\nV_Low_C = getResult(\"V1\", 1);\nV_High_C = getResult(\"V1\", 2);\nclose(\"Results\");\n\t\n// Low-density colocalization\nLow_coloc = (V_Low_C/V_Epithelial_C)/(A_Low/A_Total);\n\t\n// High-density colocalization\nHigh_coloc = (V_High_C/V_Epithelial_C)/(A_High/A_Total);\n\nTissue_type_TB = newArray(\"Low-density tissue\", \"High-density tissue\");\t\nColocalization_ratio_TB = newArray(Low_coloc,High_coloc);\n\nTable.create(\"3D localization - Vertical view\");\nTable.setColumn(\"Tissue type\", Tissue_type_TB);\nTable.setColumn(\"Colocalization ratio\", Colocalization_ratio_TB);",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
