      "d5a1beb5-3507-4950-8a57-d5b6342fddf4" : {
        "jipipe:graph-compartment" : "1231c695-771c-4237-9d5f-1aee17ca4e73",
        "jipipe:alias-id" : "multi-colocalization-analysis-h",
        "jipipe:slot-configuration" : {
          "input" : {
            "Microcolony" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Input",
              "name" : "Microcolony",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Horizontal view" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Input",
              "name" : "Horizontal view",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          },
          "output" : {
            "3D localization - Horizontal view" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Output",
              "name" : "3D localization - Horizontal view",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "" : {
            "VerticalCompact" : {
              "x" : 41,
              "y" : 22
            }
          },
          "1231c695-771c-4237-9d5f-1aee17ca4e73" : {
            "VerticalCompact" : {
              "x" : 18,
              "y" : 24
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\n\n// Remove objects on border\nselectWindow(\"Microcolony\");\nrun(\"Remove Border Labels\", \"left right top bottom\");\nsetThreshold(1, 1.000E+30, \"raw\");\nrun(\"Convert to Mask\", \"background=Dark black\");\nclose(\"Microcolony\");\n\n// Downsample inputs to reduce computation time\nselectWindow(\"Microcolony-killBorders\");\nrun(\"Scale...\", \"x=0.5 y=0.5 z=1.0 interpolation=None process create title=Microcolony-killBorders-ds\");\nselectWindow(\"Horizontal view\");\nrun(\"Scale...\", \"x=0.5 y=0.5 z=1.0 interpolation=None process create title=Horizontal-view-ds\");\nclose(\"Horizontal view\");\n\n// Microcolony volume (pix) - Total\nselectWindow(\"Microcolony-killBorders-ds\");\nrun(\"3D Volume\");\nV_Total_C=0;\nfor (row = 0; row < nResults(); row++) {\n    V_Total_C += getResult(\"Volume(Pix)\", row);\n}\nclose(\"Results\");\n\n// Microcolony volume (pix) - Epithelial compartment\nselectWindow(\"Horizontal-view-ds\");\nrun(\"Duplicate...\", \"title=Epithelial_Colonies duplicate\");\nsetThreshold(101, 255);\nrun(\"Convert to Mask\", \"background=Dark black\");\nimageCalculator(\"Multiply stack\", \"Epithelial_Colonies\",\"Microcolony-killBorders-ds\");\nrun(\"3D Volume\");\nV_Epithelial_C=0;\nfor (row = 0; row < nResults(); row++) {\n    V_Epithelial_C += getResult(\"Volume(Pix)\", row);\n}\nclose(\"Epithelial_Colonies\");\nclose(\"Results\");\n\n// Tissue type volume (pix)\nselectWindow(\"Horizontal-view-ds\");\nrun(\"3D Volume\");\nfor (row = 0; row < nResults(); row++) {\n\tif (getResult(\"LabelObj\", row)==150) {\n\t\tV_Total_Damg = getResult(\"Volume(Pix)\", row);\t\t\n\t}\n\tif (getResult(\"LabelObj\", row)==200) {\n\t\tV_Total_Tiss = getResult(\"Volume(Pix)\", row);\t\t\n\t}\n}\nclose(\"Results\");\n\t\t\t\n// Microcolony interactions with tissue types\nrun(\"3D MultiColoc\", \"image_a=Horizontal-view-ds image_b=Microcolony-killBorders-ds\");\nTable.rename(\"Colocalisation\", \"Results\");\n\n// Classification to 2 viesws\n// Horizontal view:\tQuantification of epithelial tissue penetration and vascular invasion\n// Labels:\n// Edges: 50\n// Vascular compartment: 100\n// Tissue damage: 150\n// Tissue: 200\n// Luminal compartment: 255\n\n// Number of stack classes which have colocalization with objects in microcolony channel\nselectWindow(\"Horizontal-view-ds\");\nStack.getStatistics(voxelCount, mean, min, max, stdDev);\nif (min==50) {\n\t//delete the edge class\n\tTable.deleteRows(0, 0);\t\n}\nN=nResults;\n\n// Tissue-based localization\nif (N==4) {\n\tV_Vasc_C = getResult(\"V1\", 0);\n\tV_Damg_C = getResult(\"V1\", 1);\n\tV_Tiss_C = getResult(\"V1\", 2);\n\tV_Lum_C = getResult(\"V1\", 3);\n\t\n\t// Vascular invasion\n\tVas_inv = newArray(1);\n\tArray.fill(Vas_inv, V_Vasc_C/V_Total_C);\n\t\n\t// Luminal colocalization\n\tLum_coloc = newArray(1);\n\tArray.fill(Lum_coloc, V_Lum_C/V_Total_C);\n\t\n\t// Tissue penetration\n\tTiss_pnt = newArray(1);\n\tArray.fill(Tiss_pnt, (2*V_Tiss_C)/(V_Total_Tiss+V_Epithelial_C));\n\t\n\t// Damage colocalization\n\tDamg_coloc = newArray(1);\n\tArray.fill(Damg_coloc, (2*V_Damg_C)/(V_Total_Damg+V_Epithelial_C));\n\n\tclose(\"Results\");\n\tTable.create(\"3D localization - Horizontal view\");\n\tTable.setColumn(\"Vascular invasion\", Vas_inv);\n\tTable.setColumn(\"Luminal colocalization\", Lum_coloc);\n\tTable.setColumn(\"Tissue penetration\", Tiss_pnt);\n\tTable.setColumn(\"Damage colocalization\", Damg_coloc);\n}\n// In case of no tissue damage\nif (N==3) {\n\tV_Vasc_C = getResult(\"V1\", 0);\n\tV_Tiss_C = getResult(\"V1\", 1);\n\tV_Lum_C = getResult(\"V1\", 2);\n\n\t// Vascular invasion\n\tVas_inv = newArray(1);\n\tArray.fill(Vas_inv, V_Vasc_C/V_Total_C);\n\t\n\t// Luminal colocalization\n\tLum_coloc = newArray(1);\n\tArray.fill(Lum_coloc, V_Lum_C/V_Total_C);\n\t\n\t// Tissue penetration\n\tTiss_pnt = newArray(1);\n\tArray.fill(Tiss_pnt, (2*V_Tiss_C)/(V_Total_Tiss+V_Epithelial_C));\n\t\n\t// Damage colocalization\n\tDamg_coloc = newArray(1);\n\tArray.fill(Damg_coloc,\"NaN\");\n\n\tclose(\"Results\");\n\tTable.create(\"3D localization - Horizontal view\");\n\tTable.setColumn(\"Vascular invasion\", Vas_inv);\n\tTable.setColumn(\"Luminal colocalization\", Lum_coloc);\n\tTable.setColumn(\"Tissue penetration\", Tiss_pnt);\n\tTable.setColumn(\"Damage colocalization\", Damg_coloc);\n}",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
