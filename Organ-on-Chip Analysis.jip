      "f5c6d502-7f48-4649-9471-72c22bff8c35" : {
        "jipipe:graph-compartment" : "1231c695-771c-4237-9d5f-1aee17ca4e73",
        "jipipe:alias-id" : "multi-colocalization-analysis-v",
        "jipipe:slot-configuration" : {
          "input" : {
