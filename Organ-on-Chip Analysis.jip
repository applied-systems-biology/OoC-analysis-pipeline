        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\n//setBatchMode(\"hide\");\ncall(\"ij.plugin.frame.ThresholdAdjuster.setMode\", \"B&W\");\nsetOption(\"BlackBackground\", true);\n\n// Resolution\nselectWindow(\"Microcolony\");\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\nselectWindow(\"Microcolony\");\nw = getWidth();\nh = getHeight();\nd = nSlices();\n\n// Set the minus epithelial tissue thickness to zero because the epithelial cells are appearing around membrane sometimes\nselectWindow(\"Tissue thickness\");\nrun(\"Duplicate...\", \"title=Zero-thickness\");\nsetThreshold(1.000, 1.000E+30);\nrun(\"Convert to Mask\", \"background=Dark black\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\nimageCalculator(\"Multiply create 32-bit\", \"Tissue thickness\",\"Zero-thickness\");\nclose(\"Tissue thickness\");\nclose(\"Zero-thickness\");\nselectWindow(\"Result of Tissue thickness\");\nrename(\"Tissue thickness\");\n\t\t\n////////// MEMBRANE //////////\n// Create blank image for the final results\nnewImage(\"Membrane3D\", \"8-bit black\", w, h, d);\nselectWindow(\"Membrane\");\ngetRawStatistics(nPixels, mean, min_membrane, max_membrane, std, histogram);\n\t\nsetForegroundColor(0, 0, 0);\nfor (j=min_membrane;j<=max_membrane;j++){\n    selectWindow(\"Membrane\");\n    run(\"Duplicate...\", \"title=Membrane-j\");\n\tsetThreshold(j,j);\n\trun(\"Convert to Mask\", \"background=Dark black\");    \t\n\t\n\tnewImage(\"Black\", \"8-bit black\", w, h, j-1);  \n\tdmem=d-j+1;\n\trun(\"Concatenate...\", \"  title=Membrane-j open image1=Membrane-j image2=Membrane-j image3=[-- None --]\");\n\trun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+dmem+\" interpolation=None process title=Membrane-j3D\");\t\n\trun(\"Concatenate...\", \"  title=Membrane-j3D open image1=Black image2=Membrane-j3D image3=[-- None --]\");\n\t\n    imageCalculator(\"Add stack\", \"Membrane3D\",\"Membrane-j3D\");\n    close(\"Membrane-j\");\n    close(\"Membrane-j3D\");\n}\n\t\t\n////////// TISSUE //////////\n// create blank image for the final results\nnewImage(\"Tissue3D\", \"8-bit black\", w, h, d);\t\nselectWindow(\"Interpolated epithelial tissue\");\ngetRawStatistics(nPixels, mean_tissue, min_tissue, max_tissue, std, histogram);\n\t\t\nsetForegroundColor(0, 0, 0);\nfor (j=min_tissue;j<=max_tissue;j++){\n\tselectWindow(\"Interpolated epithelial tissue\");\n    run(\"Duplicate...\", \"title=Tissue-j\");\n\tsetThreshold(j,j);\n\trun(\"Convert to Mask\", \"background=Dark black\");    \n\t\n\tnewImage(\"Black\", \"8-bit black\", w, h, j-1);          \n\tdtiss=d-j+1;\n\trun(\"Concatenate...\", \"  title=Tissue-j open image1=Tissue-j image2=Tissue-j image3=[-- None --]\");\n\trun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+dtiss+\" interpolation=None process title=Tissue-j3D\");\t\n\trun(\"Concatenate...\", \"  title=Tissue-j3D open image1=Black image2=Tissue-j3D image3=[-- None --]\");\t \n\n    // Tissue starts from first layer of stack- no black space\n    if (j==1) {\n    \tselectWindow(\"Tissue-j3D\");\n    \tsetSlice(1);\n    \trun(\"Delete Slice\");\n    }\n\n    imageCalculator(\"Add stack\", \"Tissue3D\",\"Tissue-j3D\");\n    close(\"Tissue-j\");\n    close(\"Tissue-j3D\");\t\n}\n\n////////// TISSUE DAMAGE //////////\nnewImage(\"TissueDamage3D\", \"8-bit black\", w, h, d);\nselectWindow(\"Tissue damage\");\ngetStatistics(area, mean, min, max_dmg, std, histogram);\nif (max_dmg>0) {\n\tselectWindow(\"Tissue thickness\");\n\tgetStatistics(area, mean_thickness, min, max_dmg, std, histogram);\n\tmean_thickness=round(mean_thickness);\n\t\n\tselectWindow(\"Tissue damage\");\n\trun(\"Duplicate...\", \"title=TissDamInt\");\n\trun(\"32-bit\");\n\tsetThreshold(1, 1.0000e+30);\n\trun(\"NaN Background\");\n\trun(\"Replace/Remove Label(s)\", \"label(s)=255 final=1\");\n\timageCalculator(\"Multiply 32-bit\", \"TissDamInt\",\"Membrane\");\n\trun(\"Calculator Plus\", \"i1=TissDamInt i2=TissDamInt operation=[Scale: i2 = i1 x k1 + k2] k1=1 k2=-\"+mean_thickness+\"\");\n\t\n\tgetStatistics(area, mean, min_dmg, max_dmg, std, histogram);\n\n\tsetForegroundColor(0, 0, 0);\n\tfor (j=min_dmg;j<=max_dmg;j++){\n\t\tselectWindow(\"TissDamInt\");\n\t    run(\"Duplicate...\", \"title=TissDamInt-j\");\n\t\tsetThreshold(j,j);\n\t\trun(\"Convert to Mask\", \"background=Dark black\");    \n\t\t\n\t\tnewImage(\"Black\", \"8-bit black\", w, h, j-1);          \n\t\tdtiss=d-j+1;\n\t\trun(\"Concatenate...\", \"  title=TissDamInt-j open image1=TissDamInt-j image2=TissDamInt-j image3=[-- None --]\");\n\t\trun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+dtiss+\" interpolation=None process title=TissDamInt-j3D\");\t\n\t\trun(\"Concatenate...\", \"  title=TissDamInt-j3D open image1=Black image2=TissDamInt-j3D image3=[-- None --]\");\t \n\t\n\t    // Tissue starts from first layer of stack- no black space\n\t    if (j==1) {\n\t    \tselectWindow(\"TissDamInt-j3D\");\n\t    \tsetSlice(1);\n\t    \trun(\"Delete Slice\");\n\t    }\t\t \n\t\timageCalculator(\"Add stack\", \"TissueDamage3D\",\"TissDamInt-j3D\");\n\t\tclose(\"TissDamInt-j\");\n\t\tclose(\"TissDamInt-j3D\");\n\t\t\t\n\t}\n\tclose(\"TissDamInt\");\n}\n\t\n////////// Tissue: CLASSIFICATION TO TWO CLASSES REGARDING VILLI AND CRYPTS //////////\n// Villi & Crypt masks\nselectWindow(\"Tissue thickness\");\nrun(\"Duplicate...\", \"title=Villi_mask\");\nsetAutoThreshold(\"Mean dark\");\nrun(\"Convert to Mask\");\nrun(\"Duplicate...\", \"title=Crypt_mask\");\nrun(\"Invert\");\t\n//Villi 3D\nimageCalculator(\"Multiply\", \"Villi_mask\",\"Mask\");\nrun(\"Concatenate...\", \"  title=Villi_mask open image1=Villi_mask image2=Villi_mask image3=[-- None --]\");\nrun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+d+\" interpolation=None process title=Villi3D\");\t\nclose(\"Villi_mask\");\n// Crypt 3D\t\nimageCalculator(\"Multiply\", \"Crypt_mask\",\"Mask\");\nrun(\"Concatenate...\", \"  title=Crypt_mask open image1=Crypt_mask image2=Crypt_mask image3=[-- None --]\");\nrun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+d+\" interpolation=None process title=Crypt3D\");\t\nclose(\"Crypt_mask\");\n\n\n////////// CHIP AREA MASK //////////\nselectWindow(\"Mask\");\nrun(\"Invert\");\nrun(\"Concatenate...\", \"  title=Mask open image1=Mask image2=Mask image3=[-- None --]\");\nrun(\"Scale...\", \"x=1.0 y=1.0 z=- width=\"+w+\" height=\"+h+\" depth=\"+d+\" interpolation=None process title=Edges3D\");\t\n\n\t\n// Classification to 2 viesws\n// Horizontal view:\tQuantification of epithelial tissue penetration and vascular invasion\nnewImage(\"Horizontal view\", \"8-bit black\", w, h, d);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\n// Labels:\n// Edges: 50\n// Vascular compartment: 100\n// Tissue damage: 150\n// Tissue: 200\n// Luminal compartment: 255\n\n// Mask out membrane\nselectWindow(\"Membrane3D\");\nrun(\"Duplicate...\", \"title=Membrane-maskout duplicate\");\nrun(\"Invert\", \"stack\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\n\nselectWindow(\"Edges3D\");\nrun(\"Replace value\", \"pattern=255 replacement=50\");\n\t\nselectWindow(\"Membrane3D\");\nrun(\"Replace value\", \"pattern=255 replacement=100\");\n\nimageCalculator(\"Multiply stack\", \"TissueDamage3D\",\"Membrane-maskout\");\nrun(\"Replace value\", \"pattern=255 replacement=150\");\n\nimageCalculator(\"Multiply stack\", \"Tissue3D\",\"Membrane-maskout\");\nrun(\"Replace value\", \"pattern=255 replacement=200\");\n\n// Final classification: Horizontal view\nimageCalculator(\"Add stack\", \"Horizontal view\",\"Edges3D\");\nimageCalculator(\"Add stack\", \"Horizontal view\",\"Membrane3D\");\nimageCalculator(\"Add stack\", \"Horizontal view\",\"TissueDamage3D\");\nimageCalculator(\"Add stack\", \"Horizontal view\",\"Tissue3D\");\nrun(\"Replace value\", \"pattern=0 replacement=255\");\t\n\n// Vertical view: Localization of microcolonies on epithelial tissue landscape\nnewImage(\"Vertical view\", \"8-bit black\", w, h, d);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\n// Labels:\n// Edges: 50\n// Vascular compartment: 100\n// Low-density tissue: 200\n// High-density tissue: 255\n\nimageCalculator(\"Multiply stack\", \"Crypt3D\",\"Membrane-maskout\");\nselectWindow(\"Crypt3D\");\nrun(\"Replace value\", \"pattern=255 replacement=200\");\n\nimageCalculator(\"Multiply stack\", \"Villi3D\",\"Membrane-maskout\");\n\n// Final classification: Vertical view\nimageCalculator(\"Add stack\", \"Vertical view\",\"Edges3D\");\nimageCalculator(\"Add stack\", \"Vertical view\",\"Membrane3D\");\nimageCalculator(\"Add stack\", \"Vertical view\",\"Crypt3D\");\nimageCalculator(\"Add stack\", \"Vertical view\",\"Villi3D\");\n\n// Close all except 2 output images\nlist = getList(\"image.titles\");\n// Loop through each open image and close it if the title is not an output image\nfor (i = 0; i < list.length; i++) {\n    title = list[i];\n    if (!(title== \"Horizontal view\" || title == \"Vertical view\")) {\n        close(list[i]);\n    }\n}\n\n//setBatchMode(\"show\");\t\t\t\nselectWindow(\"Horizontal view\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\nselectWindow(\"Vertical view\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\nclose(\"Results\");\nclose(\"Log\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
