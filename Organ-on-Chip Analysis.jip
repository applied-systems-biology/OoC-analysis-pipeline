      "caa97618-33c0-4c13-aa3b-6bdbef1510fe" : {
        "jipipe:graph-compartment" : "169aeb15-2bbc-44e4-95be-840f58c5343d",
        "jipipe:alias-id" : "tissue-damage",
        "jipipe:slot-configuration" : {
          "input" : {
            "ZO-1" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-16u",
              "slot-type" : "Input",
              "name" : "ZO-1",
              "custom-name" : null,
