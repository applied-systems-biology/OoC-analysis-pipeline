        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "run(\"3D Manager\");\nsetBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nsetOption(\"ExpandableArrays\", true);\n\n// Resolution\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\nselectWindow(\"Objects map\");\nStack.getStatistics(voxelCount, mean, min, N_Objs, stdDev);\n\n// If there are any objects, proceed with branch correction and if not, meaning there are no microcolonies, save the current blank image\n// Find the IDs of close Objects\nif (N_Objs>1) {\t\t\t\n\t\t\n\tselectWindow(\"Objects map\");\n\trun(\"3D Distances\", \"image_a=Objects image_b=Objects distance=DistBorderBorderUnit distance_maximum=prm_dist\");\n\tTable.rename(\"DistBorderBorderUnit\", \"Results\");\n\t\t\n\tObjs_A=newArray();\n\tObjs_B=newArray();\n\tsetOption(\"ExpandableArrays\", true);\t\t\n\t\t\n\tid=0;\n\tfor (i = 0; i < nResults(); i++) {\n\t    Obj_1 = getResult(\"LabelObj\", i);\n\t    for (obj = 1; obj < nResults(); obj++) {\n\t\t    v = getResult(\"V\" + \"\" + obj, i);\n\t\t\tif (isNaN(v)==false && v>0) {\n\t\t\t\tObj_2 = getResult(\"O\" + \"\" + obj, i);\n\t\n\t\t\t\tObjs_A[id]=Obj_1;\n\t\t\t\tObjs_B[id]=Obj_2;\n\t\t\n\t\t\t\tid++;\t\t\t\t\t\t\t\t\t\n\t\t\t}\t\t\t     \t\n\t    }\t\t\t\t\n\t}\n\tupdateResults();\n\t\t\n\t// Array of the close objs IDs\n\tObjs_A_filt=Objs_A;\n\tObjs_B_filt=Objs_B;\n\t\t\n\tinc=0;\n\tfor (i = 1; i < Objs_A.length; i++) {\n\t\tfor (j = 0; j < i; j++) {\n\t\t\n\t\t\tif (Objs_A[i]==Objs_B[j] && Objs_A[j]==Objs_B[i] && i!=j) {\n\t\t\t\n\t\t\t\tObjs_A_filt=Array.deleteIndex(Objs_A_filt, i-inc);\n\t\t\t\tObjs_B_filt=Array.deleteIndex(Objs_B_filt, i-inc);\n\t\t\n\t\t\t\tinc++;\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t}\t\t\t\t\n\t\t}\t\t\n\t}\n\t\t\t\t\n\tclose(\"Results\");\t\t\n\t\t\n\t// Dupliacte the original segmentation (\"Objects map-1\")\n\tselectWindow(\"Objects map\");\n\trun(\"Duplicate...\", \"duplicate\");\n\t\t\n\t// Add the new image to Roi manager\n\tselectWindow(\"Objects map\");\n\trun(\"Select None\");\n\tExt.Manager3D_AddImage();\t\t\t\n\t\t\n\t// Loop over the close objects to reconstruct the branches\n\tExt.Manager3D_Count(nb);\n\tfor (obj_i=0; obj_i<Objs_A_filt.length; obj_i++) {\n\t\n\t\t\t\ti=Objs_A_filt[obj_i]-1;\n\t\t\t\tj=Objs_B_filt[obj_i]-1;\n\t\t\t\t\t\t\t\t\t\n\t\t\t\tExt.Manager3D_Dist2(i,j,\"bb\",dist_micron);\n\t\t\t\n\t\t\t\tExt.Manager3D_GetName(i, namei);\n\t\t\t\tExt.Manager3D_GetName(j, namej);\n\t\t\t\n\t\t\t\tprint(namei);\n\t\t\t\tprint(namej); \n\t\t\t\tprint(dist_micron);   \n\t\t\t\t\n\t\t\t\tprint(\"they are close, analyze the sub-region\");\n\t\t\t\tdist = dist_micron/ResXY;\n\t\t\t\t\t\n\t\t\t\tname=split(namei,\"l\");\n\t\t\t\tlabel_i=name[1];\n\t\t\n\t\t\t\tname=split(namej,\"l\");\n\t\t\t\tlabel_j=name[1];\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t// Get the bounding box\n\t\t\t\tExt.Manager3D_Bounding3D(i,x_min_i,x_max_i,y_min_i,y_max_i,z_min_i,z_max_i);\n\t\t\t\tExt.Manager3D_Bounding3D(j,x_min_j,x_max_j,y_min_j,y_max_j,z_min_j,z_max_j);\t\t\t\t\n\t\t\n\t\t\t\t//Intersection of the bounding boxes\t\t\t\t\t\n\t\t\t\tx_left=maxOf(x_min_i, x_min_j);\n\t\t\t\tx_right=minOf(x_max_i, x_max_j);\n\t\t\t\t\t\n\t\t\t\ty_bottom=maxOf(y_min_i, y_min_j);\n\t\t\t\ty_top=minOf(y_max_i, y_max_j);\n\t\t\t\t\t\n\t\t\t\t// In case of no overlap: Increase the bounding box over the border-to-border distance until you find an overlap\n\t\t\t\tinc=1;\t\t\t\t\n\t\t\t\twhile ((x_right<x_left) | (y_bottom>y_top)) {\n\t\t\t\t\t\n\t\t\t\t\tx_left=maxOf(x_min_i-(inc), x_min_j-(inc));\n\t\t\t\t\tx_right=minOf(x_max_i+(inc), x_max_j+(inc));\n\t\t\t\t\t\t\n\t\t\t\t\ty_bottom=maxOf(y_min_i-(inc), y_min_j-(inc));\n\t\t\t\t\ty_top=minOf(y_max_i+(inc), y_max_j+(inc));\n\t\t\n\t\t\t\t\tinc=inc+1;\n\t\t\t\t}\n\t\t\n\t\t\t\tx_min=x_left;\n\t\t\t\tx_max=x_right;\n\t\t\t\ty_min= y_bottom;\n\t\t\t\ty_max=y_top;\n\n\t\t\t\tdist=dist+prm_add;\n\t\t\n\t\t\t\tselectWindow(\"Enhanced signal\");\n\t\t\t\tsetTool(\"rectangle\");\n\t\t\t\tmakeRectangle(x_min-(1*dist), y_min-(1*dist), x_max-x_min+(2*dist), y_max-y_min+(2*dist));\n\t\t\t\trun(\"Duplicate...\", \"title=sub-region duplicate\");\n\t\t\t\t\n\t\t\t\t// Rolling Boll Radius: find the maximum feret diameter of the largest region of interest\t\t\t\t\t\n\t\t\t\trun(\"Z Project...\", \"projection=[Max Intensity]\");\n\t\t\t\trename(\"RBR\");\n\t\t\t\tsetAutoThreshold(\"\"+prm_thrsh+\" dark stack\");\n\t\t\t\trun(\"Make Binary\", \"method=\"+prm_thrsh+\" background=Dark black\");\n\t\t\t\trun(\"Keep Largest Region\");\t\t\t\t\n\t\t\t\trun(\"Max. Feret Diameters\", \"label=RBR-largest image=RBR-largest\");\n\t\t\t\tTable.rename(\"RBR-largest-FeretDiams\", \"Results\");\n\t\t\t\tRBR = (getResult(\"Diameter\", 0)/ResXY)/2;\n\t\t\t\tclose(\"RBR\");\n\t\t\t\tclose(\"RBR-largest\");\n\t\t\t\tclose(\"Results\");\n\t\t\n\t\t\t\t// Subtract the background\n\t\t\t\tselectWindow(\"sub-region\");\n\t\t\t\trun(\"Subtract Background...\", \"rolling=\"+RBR+\" stack\");\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t// Double check in the sub-region for possible branch disconnections\n\t\t\t\t// Duplicate the sub-region from Objects map\n\t\t\t\tselectWindow(\"Objects map\");\n\t\t\t\tsetTool(\"rectangle\");\n\t\t\t\tmakeRectangle(x_min-(1*dist), y_min-(1*dist), x_max-x_min+(2*dist), y_max-y_min+(2*dist));\n\t\t\t\trun(\"Duplicate...\", \"duplicate\");\n\t\t\t\trename(\"Objects_map_of_sub-region-original\");\n\t\t\t\t\n\t\t\t\t// Apply intensity thresholding on the enhanced sub-region\n\t\t\t\tselectWindow(\"sub-region\");\n\t\t\t\tsetAutoThreshold(\"\"+prm_thrsh+\" dark stack\");\n\t\t\t\tgetThreshold(lower, upper);\n\t\t\t\tval=lower;\n\t\t\t\tselectWindow(\"sub-region\");\n\t\t\t\trun(\"3D Objects Counter\", \"threshold=\"+val+\" slice=44 min.=20 max.=1.000E+30 objects\");\n\t\t\t\trename(\"Objects_map_of_sub-region_\");\t\t\n\t\t\t\t\t\n\t\t\t\t// Get the IDs of the objects in the objects map sub-region to zoom in\n\t\t\t\t// Clear roi manager\n\t\t\t\tExt.Manager3D_Reset();\n\t\t\t\t\t\n\t\t\t\tselectWindow(\"Objects_map_of_sub-region-original\");\n\t\t\t\tExt.Manager3D_AddImage();\n\t\t\t\t\t\n\t\t\t\tExt.Manager3D_Count(nb_);\n\t\t\t\tfor (s=0; s<nb_; s++) {\n\t\t\t\t\t\n\t\t\t\t\tExt.Manager3D_GetName(s, name_s);\n\t\t\t\t\tname=split(name_s,\"l\");\n\t\t\t\t\tlabel=name[1];\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t\tif (label==label_i){\n\t\t\t\t\t\ti_ = s;\n\t\t\t\t\t}\n\t\t\t\t\tif (label==label_j){\n\t\t\t\t\t\tj_ = s;\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\n\t\t\t\t// Get the bounding box_2: Zooming in\n\t\t\t\tExt.Manager3D_Bounding3D(i_,x_min_i_,x_max_i_,y_min_i_,y_max_i_,z_min_i_,z_max_i_);\n\t\t\t\tExt.Manager3D_Bounding3D(j_,x_min_j_,x_max_j_,y_min_j_,y_max_j_,z_min_j_,z_max_j_);\n\t\t\t\t\t\t\t\t\n\t\t\t\t// Intersection of the bounding boxes_2\n\t\t\t\tdist = dist_micron/ResXY;\n\t\t\t\t\t\n\t\t\t\tx_left_=maxOf(x_min_i_, x_min_j_);\n\t\t\t\tx_right_=minOf(x_max_i_, x_max_j_);\n\t\t\t\t\t\n\t\t\t\ty_bottom_=maxOf(y_min_i_, y_min_j_);\n\t\t\t\ty_top_=minOf(y_max_i_, y_max_j_);\n\t\t\t\t\t\n\t\t\t\t// In case of no overlap: Increase the bounding box over the border-to-border distance until you find an overlap\n\t\t\t\tinc=1;\n\t\t\t\twhile ((x_right_<x_left_) | (y_bottom_>y_top_)) {\n\t\t\t\t\t\n\t\t\t\t\tx_left_=maxOf(x_min_i_-(inc), x_min_j_-(inc));\n\t\t\t\t\tx_right_=minOf(x_max_i_+(inc), x_max_j_+(inc));\n\t\t\t\t\t\n\t\t\t\t\ty_bottom_=maxOf(y_min_i_-(inc), y_min_j_-(inc));\n\t\t\t\t\ty_top_=minOf(y_max_i_+(inc), y_max_j_+(inc));\n\t\t\n\t\t\t\t\tinc=inc+1;\n\t\t\t\t}\n\t\t\n\t\t\t\tx_min_=x_left_;\n\t\t\t\tx_max_=x_right_;\n\t\t\t\ty_min_= y_bottom_;\n\t\t\t\ty_max_=y_top_;\n\t\t\t\t\t\t\t\n\t\t\t\tselectWindow(\"sub-region\");\n\t\t\t\tsetTool(\"rectangle\");\n\t\t\t\tmakeRectangle(x_min_-(1*dist), y_min_-(1*dist), x_max_-x_min_+(2*dist), y_max_-y_min_+(2*dist));\n\t\t\t\trun(\"Duplicate...\", \"title=sub-region_ duplicate\");\n\t\t\t\t\t\n\t\t\t\tsetAutoThreshold(\"\"+prm_thrsh+\" dark stack\");\n\t\t\t\tgetThreshold(lower, upper);\n\t\t\t\tval=lower;\n\t\t\t\tselectWindow(\"sub-region_\");\n\t\t\t\trun(\"3D Objects Counter\", \"threshold=\"+val+\" slice=44 min.=20 max.=1.000E+30 objects\");\n\t\t\t\trename(\"Objects_map_of_sub-region__\");\t\t\t\n\t\t\t\t\t\t\t\t\n\t\t\t\tselectWindow(\"Objects_map_of_sub-region__\");\n\t\t\t\trename(\"Objects-map-of-sub-region__\");\n\t\t\t\tx_min1_=x_min_-(1*dist);\n\t\t\t\ty_min1_=y_min_-(1*dist);\n\t\t\t\t\t\n\t\t\t\tif (x_min1_<0) {\n\t\t\t\t\tx_min1_=0;\n\t\t\t\t}\n\t\t\t\tif (y_min1_<0) {\n\t\t\t\t\ty_min1_=0;\n\t\t\t\t}\n\t\t\n\t\t\t\trun(\"Insert...\", \"source=Objects-map-of-sub-region__ destination=[Objects_map_of_sub-region_] x=\"+x_min1_+\" y=\"+y_min1_+\"\");\n\t\t\t\t\n\t\t\t\tselectWindow(\"Objects_map_of_sub-region_\");\n\t\t\t\trun(\"3D Objects Counter\", \"threshold=1 slice=44 min.=200 max.=1.000E+30 objects\");\n\t\t\t\trename(\"Objects_map_of_sub-region\");\t\t\t\t\t\t\t\t\t\n\t\n\t\t\t\tclose(\"sub-region_\");\n\t\t\t\tclose(\"Objects-map-of-sub-region__\");\n\t\t\t\tclose(\"Objects_map_of_sub-region_\");\t\n\t\t\t\t\t\t\t\t\n\t\t\t\t// To avoid noise: only keep the overlapping objects in the sub region\n\t\t\t\tselectWindow(\"Objects_map_of_sub-region-original\");\n\t\t\t\tsetThreshold(1.000, 1.000E+30);\n\t\t\t\trun(\"Convert to Mask\", \"background=Dark black\");\n\t\t\t\trun(\"Replace value\", \"pattern=255 replacement=1\");\n\t\t\t\timageCalculator(\"Multiply stack\", \"Objects_map_of_sub-region-original\",\"Objects_map_of_sub-region\");\n\t\t\t\t\t\n\t\t\t\trun(\"Label Overlap Measures\", \"source=[Objects_map_of_sub-region] target=[Objects_map_of_sub-region-original] overlap jaccard dice volume false false_0\");\n\t\t\t\tclose(\"Objects_map_of_sub-region-all-labels-overlap-measurements\");\n\t\t\t\tclose(\"Results\");\n\t\t\t\tTable.rename(\"Objects_map_of_sub-region-individual-labels-overlap-measurements\", \"Results\");\n\n\t\t\t\tfor (t = 0; t < nResults(); t++) {\n\t\t\t\t    label_obj = t+1;\t\t\t\t\t\n\t\t\t\t\toverlap = getResult(\"TargetOverlap\", t);\t\t\t\t\n\t\t\t\t\tselectWindow(\"Objects_map_of_sub-region\");\n\t\t\t\t\tif (overlap!=0) {\n\t\t\t\t\t\trun(\"Replace/Remove Label(s)\", \"label(s)=\"+label_obj+\" final=255\");\t\t\t\t\t\t\n\t\t\t\t\t} else {\n\t\t\t\t\t\trun(\"Replace/Remove Label(s)\", \"label(s)=\"+label_obj+\" final=0\");\n\t\t\t\t\t}\t\t\t\t\t\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\tselectWindow(\"Objects_map_of_sub-region\");\n\t\t\t\trename(\"Objects-map-of-sub-region\");\n\t\t\t\tdist=dist+prm_add;\n\t\t\t\tx_min1=x_min-(1*dist);\n\t\t\t\ty_min1=y_min-(1*dist);\n\t\t\t\t\t\n\t\t\t\tif (x_min1<0) {\n\t\t\t\t\tx_min1=0;\n\t\t\t\t}\n\t\t\t\tif (y_min1<0) {\n\t\t\t\t\ty_min1=0;\n\t\t\t\t}\n\t\t\n\t\t\t\trun(\"Insert...\", \"source=Objects-map-of-sub-region destination=[Objects map-1] x=\"+x_min1+\" y=\"+y_min1+\"\");\n\t\t\t\t\t\t\t\t\n\t\t\t\tclose(\"Objects_map_of_sub-region-original\");\n\t\t\t\tclose(\"sub-region\");\n\t\t\t\tclose(\"Objects-map-of-sub-region\");\n\t\t\t\t\t\t\t\t\n\t\t\t\t// Clear roi manager\n\t\t\t\tExt.Manager3D_Reset();\n\t\t\t\t\n\t\t\t\tselectWindow(\"Objects map\");\n\t\t\t\trun(\"Select None\");\n\t\t\t\tExt.Manager3D_AddImage();\n\t}\t\t\t\n\t// Clear roi manager\n\tExt.Manager3D_Reset();\t\n\tclose(\"Results\");\n\t\t\n\tselectWindow(\"Objects map-1\");\n\tsetThreshold(1.000, 1.000E+30);\n\trun(\"Convert to Mask\", \"background=Dark black\");\n\trun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\n\trun(\"Connected Components Labeling\", \"connectivity=26 type=[8 bits]\");\n\trun(\"Fire\");\n\trun(\"Enhance Contrast\", \"saturated=0.35\");\n\n\tclose(\"\\\\Others\");\n\tclose(\"Results\");\n\tclose(\"Log\");\n\t\t\n\tsetBatchMode(\"show\");\n\trename(\"Reconstructed signal\");\t\n\t\t\n} else {\t\t\n\t// Connected components labeling with Particle Analyser\n\tselectWindow(\"Objects map\");\n\tsetThreshold(1.000, 1.000E+30);\n\trun(\"Convert to Mask\", \"background=Dark black\");\n\trun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\n\trun(\"Connected Components Labeling\", \"connectivity=26 type=[8 bits]\");\n\trun(\"Fire\");\n\trun(\"Enhance Contrast\", \"saturated=0.35\");\n\t\t\n\tclose(\"\\\\Others\");\n\tclose(\"Results\");\n\tclose(\"Log\");\n\t\t\t\n\tsetBatchMode(\"show\");\n\trename(\"Reconstructed signal\");\t\n}",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
