              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Segmentation" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Output",
              "name" : "Segmentation",
              "custom-name" : null,
