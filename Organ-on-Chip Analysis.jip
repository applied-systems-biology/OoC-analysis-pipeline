      "85ca79c1-2cdb-450a-a462-14a125a0d8cc" : {
        "jipipe:graph-compartment" : "fb3bfe3a-c9c1-4ec4-908b-3f1b7380a851",
        "jipipe:alias-id" : "signal-enhancement-objects-dete",
        "jipipe:slot-configuration" : {
          "input" : {
            "Microcolony" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-16u",
              "slot-type" : "Input",
              "name" : "Microcolony",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Mask" : {
              "slot-data-type" : "imagej-imgplus-2d-greyscale-mask",
              "slot-type" : "Input",
              "name" : "Mask",
              "custom-name" : null,
