      "a59e8af1-cd9a-4437-9d7a-bd51934a8089" : {
        "jipipe:graph-compartment" : "fb3bfe3a-c9c1-4ec4-908b-3f1b7380a851",
        "jipipe:alias-id" : "watershed-splitting",
        "jipipe:slot-configuration" : {
          "input" : {
            "Reconstruted signal" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Input",
              "name" : "Reconstruted signal",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          },
          "output" : {
            "Watershed segmentation" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Output",
              "name" : "Watershed segmentation",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "fb3bfe3a-c9c1-4ec4-908b-3f1b7380a851" : {
            "VerticalCompact" : {
              "x" : 13,
              "y" : 24
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "run(\"3D Manager\");\nsetBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nsetOption(\"ExpandableArrays\", true);\n\t\n// Resolution\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\nrename(\"Reconstructed_signal\");\n\t\nrun(\"Duplicate...\", \"title=Original duplicate\");\nsetThreshold(1.0000, 1.000E+30);\nrun(\"Convert to Mask\", \"background=Dark black\");\t\n\nselectWindow(\"Reconstructed_signal\");\nrun(\"Z Project...\", \"projection=[Max Intensity]\");\nrun(\"Max. Feret Diameters\", \"label=[MAX_Reconstructed_signal] image=[MAX_Reconstructed_signal]\");\t\nTable.rename(\"MAX_Reconstructed_signal-FeretDiams\", \"Results\");\nclose(\"MAX_Reconstructed_signal\");\n\nvar indexlist;\nindexlist = newArray();\t\nj=0;\nfor (i = 0; i < nResults(); i++) {\n    crit_dim = getResult(\"Diameter\", i);  \n    if (crit_dim>prm_size) {\n    \tindexlist[j] = i;\n    \tj+=1;\n\t}   \n}\n//Array.show(indexlist);\t\n\t\t\n// in case there are any objs to filter\nif (indexlist.length>0) {\n\tselectWindow(\"Reconstructed_signal\");\n\tExt.Manager3D_AddImage();\t\n\tExt.Manager3D_SelectAll();\n\tExt.Manager3D_MultiSelect();\n\tfor (j=0; j<indexlist.length; j++) {\n\t\tExt.Manager3D_Select(indexlist[j]);\n\t}\n\tExt.Manager3D_FillStack(0, 0, 0);\n\tExt.Manager3D_Delete();\n\t\t\t\n\t//Reset roi manager\n\tExt.Manager3D_Reset();\n\tclose(\"Results\");\t\t\n}\n\nselectWindow(\"Reconstructed_signal\");\nsetThreshold(1.0000, 1.000E+30);\nrun(\"Convert to Mask\", \"background=Dark black\");\t\nimageCalculator(\"Subtract stack\", \"Original\",\"Reconstructed_signal\");\nrename(\"Microcolony-Individual\");\n\nselectWindow(\"Reconstructed_signal\");\nrun(\"Connected Components Labeling\", \"connectivity=26 type=[8 bits]\");\nrename(\"Microcolony\");\nclose(\"Reconstructed_signal\");\n\nselectWindow(\"Microcolony\");\nw = getWidth();\nh = getHeight();\nd = nSlices;\n\t\t\nnewImage(\"Final_Segmentation\", \"16-bit black\", w, h, d);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\nnewImage(\"Segmentation\", \"16-bit black\", w, h, d);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\n\nselectWindow(\"Microcolony\");\nrun(\"Bounding Box 3D\");\nTable.applyMacro(\"Width=Box_XMax-Box_XMin; \", \"Microcolony-bbox\");\nTable.applyMacro(\"Height=Box_YMax-Box_YMin; \", \"Microcolony-bbox\");\t\nTable.rename(\"Microcolony-bbox\", \"Results\");\t\n\t\t\nselectWindow(\"Microcolony\");\nExt.Manager3D_AddImage();\n\t\nExt.Manager3D_Count(nb);\nfor (i=0; i<nb; i++) {\n\n\tExt.Manager3D_GetName(i, name_i);\n\tname=split(name_i,'l');\n\tl=name[1];\t\n\t\t\t\t\n\tx= getResult(\"Box.XMin\", i)/ResXY;\n\ty= getResult(\"Box.YMin\", i)/ResXY;\n\twidth= getResult(\"Width\", i)/ResXY;\n\theight= getResult(\"Height\", i)/ResXY;\n\t//free the result table\n\tTable.rename(\"Results\", \"Results-1\");\t\n\tselectWindow(\"Microcolony\");\t\n\tx1=x-50;\t\t\n\ty1=y-50;\n\tif (x1<0) {\n\t\tx1=0;\n\t}\n\tif (y1<0) {\n\t\ty1=0;\n\t}\n\t\t\n\tselectWindow(\"Microcolony\");\n\tmakeRectangle(x1, y1, width+100, height+100);\n\t\t\t\t\t\t\t\n\trun(\"Duplicate...\", \"title=Microcolony-W duplicate\");\n\tsetThreshold(l, l);\n\trun(\"Convert to Mask\", \"background=Dark black\");\n\t\n\t//Sead estimation in 2D\n\trun(\"Z Project...\", \"projection=[Max Intensity]\");\n\trun(\"Morphological Filters\", \"operation=Closing element=Square radius=prm_cls\");\t\n\trun(\"Morphological Filters\", \"operation=Opening element=Square radius=prm_opn\");\t\n\trun(\"Fill Holes\");\n\trun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\n\tsetThreshold(1.000, 1.000E+30);\n\trun(\"Convert to Mask\", \"background=Dark black\");\n\trun(\"Connected Components Labeling\", \"connectivity=8 type=[8 bits]\");\n\tclose(\"Results\");\n\trename(\"seeds2D\");\t\n\t\n\t// Scale seeds to 3D\n\tselectWindow(\"Microcolony-W\");\n\tw_w=getWidth();\n\th_w=getHeight();\n\td_w=nSlices;\n\trun(\"Concatenate...\", \"  title=seeds image1=seeds2D image2=seeds2D image3=[-- None --]\");\n\trun(\"Scale...\", \"width=\"+w_w+\" height=\"+h_w+\" depth=\"+d_w+\" interpolation=None process create title=seeds3D\");\n\tclose(\"seeds\");\n\n\t//Splitting\n\trun(\"3D Watershed Split\", \"binary=Microcolony-W seeds=seeds3D radius=2\"); //Split 16-bit\n\t\t\t\t\t\t\t\t\t\n\trun(\"Insert...\", \"source=Split destination=[Segmentation] x=\"+x1+\" y=\"+y1+\"\");\n\t\t\n\timageCalculator(\"Add stack\", \"Final_Segmentation\",\"Segmentation\");\n\n\tselectWindow(\"Segmentation\");\t\n\tmakeRectangle(x-50, y-50, width+100, height+100);\n\trun(\"Clear\", \"stack\");\n\t\t\n\t//waitForUser;\n\t\t\t\n\tclose(\"Microcolony-W\");\n\tclose(\"MAX_Microcolony-W\");\n\tclose(\"MAX_Microcolony-W-Erosion\");\n\tclose(\"MAX_Microcolony-W-Erosion-Opening\");\n\tclose(\"MAX_Microcolony-W-Erosion-Opening_parts\");\n\tclose(\"seeds3D\");\n\tclose(\"EDT\");\n\tclose(\"Split\");\n\t\t\n\tTable.rename(\"Results-1\", \"Results\");\n\t\t\t\n}\nExt.Manager3D_Reset();  \n\t\n//free space\nclose(\"Microcolony\");\nclose(\"Segmentation\");\n\t\t\nimageCalculator(\"Add stack\", \"Final_Segmentation\",\"Microcolony-Individual\");\n\t\t\nselectWindow(\"Final_Segmentation\");\t\t\t\t\nrun(\"Connected Components Labeling\", \"connectivity=26 type=[8 bits]\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\t\t\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\n\t\t\t\nsetBatchMode(\"show\");\nrename(\"Watershed segmentation\");\t\t",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
