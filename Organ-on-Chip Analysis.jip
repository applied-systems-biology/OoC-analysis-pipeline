        "jipipe:algorithm:runtime-partition" : {
          "index" : 0
        },
        "jipipe:node:description" : "<html><head></head><body></body></html>",
        "generated-annotations" : {
          "template" : {
            "parameters" : {
              "annotation-name" : {
                "key" : "annotation-name",
                "name" : "Annotation name",
                "description" : "An expression that generates the annotation name",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"Annotation name\""
                },
                "short-key" : "annotation-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "annotation-value" : {
                "key" : "annotation-value",
                "name" : "Annotation value",
                "description" : "An expression that generates the annotation value\n\nThis function should return a valid file path string, which can be either hardcoded or built using string or <code>PATH_COMBINE</code> operations.\n\nHard-cording file paths: Just type the path into quotes as shown below <pre>\"C:/MyData/Outputs/Output_file\"</pre>\n\nUsing path combination: You can combine combine variables provided from annotations and expression variables to, for example, save create a path relative to the project directory or to a project user directory<pre>PATH_COMBINE(project_dir, \"Outputs\", \"Output_file\")</pre><pre>PATH_COMBINE(project_data_dirs [\"outputs\"], \"Outputs\", \"Output_file\")</pre>Alternative: <pre>PATH_COMBINE(project_data_dir.outputs, \"Outputs\", \"Output_file\")</pre>\n\nUsing expression functions: You can also use the standard string concatenation function to generate paths<pre>project_dir + \"/Outputs/Output_file\"</pre>",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.DataExportExpressionParameter",
                "value" : {
                  "expression" : "PATH_COMBINE(data_dir, auto_file_name)"
                },
                "short-key" : "annotation-value",
                "ui-order" : 0,
                "field-class-id" : "data-export-expression"
              }
            }
          },
          "items" : [ {
            "parameters" : {
              "annotation-name" : {
                "key" : "annotation-name",
                "name" : "Annotation name",
                "description" : "An expression that generates the annotation name",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"#Replicate\""
                },
                "short-key" : "annotation-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "annotation-value" : {
                "key" : "annotation-value",
                "name" : "Annotation value",
                "description" : "An expression that generates the annotation value\n\nThis function should return a valid file path string, which can be either hardcoded or built using string or <code>PATH_COMBINE</code> operations.\n\nHard-cording file paths: Just type the path into quotes as shown below <pre>\"C:/MyData/Outputs/Output_file\"</pre>\n\nUsing path combination: You can combine combine variables provided from annotations and expression variables to, for example, save create a path relative to the project directory or to a project user directory<pre>PATH_COMBINE(project_dir, \"Outputs\", \"Output_file\")</pre><pre>PATH_COMBINE(project_data_dirs [\"outputs\"], \"Outputs\", \"Output_file\")</pre>\n\nUsing expression functions: You can also use the standard string concatenation function to generate paths<pre>project_dir + \"/Outputs/Output_file\"</pre>",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.DataExportExpressionParameter",
                "value" : {
                  "expression" : "SUBSTRING($\"data_string\", STRING_LAST_INDEX_OF($\"data_string\", \"Rep\")+3, STRING_LAST_INDEX_OF($\"data_string\", \"Rep\")+4)"
                },
                "short-key" : "annotation-value",
                "ui-order" : 0,
                "field-class-id" : "data-export-expression"
              }
            }
