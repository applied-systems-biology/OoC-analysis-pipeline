        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "run(\"3D Manager\");\nsetBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nsetOption(\"ExpandableArrays\", true);\n\n// Filter Objects by volume\nselectWindow(\"Segmentation\");\nrun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\nclose(\"Results\");\nrename(\"Objects map of original\");\nclose(\"Segmentation\");\n\nrun(\"3D Intensity Measure\", \"objects=Objects signal=Enhanced\");\nrun(\"3D Ellipsoid measure\");\n\nindexlist = newArray();\nj=0;\nfor (i = 0; i < nResults()/2; i++) {\n    crit_avg = getResult(\"IntensityAvg\", i*2);\n    crit_spr = getResult(\"EllSpareness\", i*2+1);\n    if ((crit_avg<prm_avgint) | (crit_spr>prm_spr)) {\n    \tindexlist[j] = i;\n    \tj+=1;\n\t}   \n}\n\n// in case there are any objs with an average intensity lower than prm_avgint or sparseness higher than prm_spr to filter out:\nif (indexlist.length>0) {\n\tselectWindow(\"Objects map of original\");\n\tExt.Manager3D_AddImage()\t\n\tExt.Manager3D_MultiSelect();\n\tfor (j=0; j<indexlist.length; j++) {\n\t\tExt.Manager3D_Select(indexlist[j]);\n\t}\n\tExt.Manager3D_FillStack(0, 0, 0);\n\tExt.Manager3D_Delete();\n\t\t\n\tExt.Manager3D_Reset();\n\tclose(\"Results\");\t\t\n}\n\t\t\n// Connected Components Labeling\t\nselectWindow(\"Objects map of original\");\nrun(\"Connected Components Labeling\", \"connectivity=26 type=[8 bits]\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\n\nsetBatchMode(\"show\");\nrename(\"Objects map\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
