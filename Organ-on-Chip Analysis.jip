        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\nrun(\"Select None\");\n\n// Resolution\nselectWindow(\"Nuclei\");\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\n// Exclude edges and artifacts\nselectWindow(\"Maskout\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\nimageCalculator(\"Multiply stack\", \"Nuclei\",\"Maskout\");\nrename(\"Enhanced signal\");\nclose(\"Maskout\");\n\n// Signal enhancement\nrun(\"Mean 3D...\", \"x=prm_mn y=prm_mn z=prm_mn\");\n\n// Local thresholding\nselectWindow(\"Enhanced signal\");\nw = getWidth();\nh = getHeight();\nd=nSlices();\n\t\n// Create blank image for the final results\nnewImage(\"Final_Result\", \"8-bit black\", w, h, d);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\n\n// Slide over the enhanced image\nfor (iii=0;iii<round(h/prm_stepsize);iii++){\n\tfor (ii=0;ii<round(w/prm_stepsize);ii++){\n    \trun(\"Clear Results\");\n        x=ii*prm_stepsize;\n        y=iii*prm_stepsize;\n\t\n        selectWindow(\"Enhanced signal\");\n        makeRectangle(x, y, prm_area, prm_area);\n        run(\"Duplicate...\", \"title=Nuclei-W duplicate\");\n\t        \n        setAutoThreshold(\"\"+prm_thrsh+\" dark stack\");\n        getThreshold(lower, upper);\n        run(\"Convert to Mask\", \"method=\"+prm_thrsh+\" background=Dark black\");\n\t               \n        selectWindow(\"Final_Result\");\n        makeRectangle(x, y, prm_area, prm_area);\n        run(\"Duplicate...\", \"title=Final_Result-W duplicate\");\n\t        \n\t\t//avoid segmenting outside edges!\n\t\tif (lower>0) {\n        imageCalculator(\"Add stack\", \"Nuclei-W\",\"Final_Result-W\");\n        run(\"Insert...\", \"source=Nuclei-W destination=Final_Result x=x y=y\");\t\t\t\n\t\t}\n \t\n        close(\"Nuclei-W\");\n        close(\"Final_Result-W\");\n\t\n\t\tclose(\"Results\");\n\t\n\t}\n}\n\n// Filter the size by 500 micron³\nrun(\"Particle Analyser\", \"  min=prm_vol max=Infinity surface_resampling=2 show_particle surface=Gradient split=0.000 volume_resampling=2\");\nsetThreshold(1.000, 1.000E+30);\nrun(\"Convert to Mask\", \"background=Dark black\");\n\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\nrun(\"Collect Garbage\");\n\nsetBatchMode(\"show\");\nrename(\"Nuclei segmentation\");",
          "collapsed" : false,
