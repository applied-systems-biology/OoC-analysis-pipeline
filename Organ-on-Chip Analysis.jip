        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nrun(\"Select None\");\nrun(\"Set Measurements...\", \"standard stack redirect=None decimal=3\");\nsetOption(\"ExpandableArrays\", true);\n\n// Resolution\nselectWindow(\"BF-Enhanced\");\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\nselectWindow(\"BF-Enhanced\");\nw=getWidth();\nh=getHeight();\nd=nSlices;\n\n//Limit the search area in XY\nselectWindow(\"BF-Thresholded-Dilation\");\nrun(\"Replace value\", \"pattern=255 replacement=1\");\nimageCalculator(\"Multiply stack\", \"BF-Enhanced\",\"BF-Thresholded-Dilation\");\n\n//Exclude edges and artifacts\nselectWindow(\"Mask\");\nrename(\"Edge\");\nrun(\"32-bit\");\nsetThreshold(255.000, 1.000E+30);\nrun(\"NaN Background\");\nrun(\"Replace/Remove Label(s)\", \"label(s)=255 final=1\");\n\t\nimageCalculator(\"Multiply create 32-bit stack\", \"BF-Enhanced\",\"Edge\");\nrename(\"BF-Enhanced-32bit\");\n\n// Create blank image for the final results\nnewImage(\"Final_Result\", \"32-bit black\", w, h, 1);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\nimageCalculator(\"Multiply\", \"Final_Result\",\"Edge\");\n\n// Slide over the enhanced image\nfor (iii=0;iii<round(h/prm_stepsize)-1;iii++){\n\tfor (ii=0;ii<round(w/prm_stepsize)-1;ii++){\n    \trun(\"Clear Results\");\n        x=ii*prm_stepsize;\n        y=iii*prm_stepsize;\n\t\n\t\t// Measure the std of the enhanced signanl\n\t\tselectWindow(\"BF-Enhanced-32bit\");\n        makeRectangle(x, y, prm_area, prm_area);\n\t\trun(\"Measure Stack...\");\n\t\t\n\t\tlist_std = newArray();\t\t\n\t\tfor (i = 0; i < nResults(); i++) {\n\t\t    std = getResult(\"StdDev\", i);\n\t\t   \tlist_std[i] = std;  \n\t\t}\n\t\t\n\t\t// Get the slice with the maximum STD\n\t\tArray.getStatistics(list_std, min, max, mean, stdDev);\n\t\t\n\t\tfor (i = 0; i < nResults(); i++) {\n\t\t    std = getResult(\"StdDev\", i);\n\t\t    if (std==max){\n\t\t    \tslice = getResult(\"Slice\", i);\n\t\t    }\n\t\t}\n\t\t\t\n\t\t// Create blank image for inserting the slice information\n\t\tnewImage(\"New\", \"32-bit black\", prm_area, prm_area, 1);\n\t\trun(\"Replace/Remove Label(s)\", \"label(s)=0 final=\"+slice+\"\");\n\t\n\t\tselectWindow(\"Final_Result\");\n\t\tsetTool(\"rectangle\");\n\t\tmakeRectangle(x, y, prm_area, prm_area);\n\t\trun(\"Duplicate...\", \"title=Final_Result_W duplicate\");\n\t\n\t\tselectWindow(\"Final_Result_W\");\n\t\trun(\"Duplicate...\", \"title=Final_Result_W_overlapping duplicate\");\n\t\tsetThreshold(1, 255);\n\t\trun(\"Convert to Mask\", \"method=Default background=Dark black\");\n\t\tselectWindow(\"Final_Result_W_overlapping\");\n\t\trun(\"Duplicate...\", \"title=Final_Result_W_non_overlapping duplicate\");\n\t\trun(\"Invert\");\n\t\t\t\n\t\tselectWindow(\"Final_Result_W_overlapping\");\n\t\trun(\"32-bit\");\n\t\tselectWindow(\"Final_Result_W_non_overlapping\");\n\t\trun(\"32-bit\");\n\t\t\t\n\t\trun(\"Replace/Remove Label(s)\", \"label(s)=255 final=1\");\n\t\tselectWindow(\"Final_Result_W_overlapping\");\n\t\trun(\"Replace/Remove Label(s)\", \"label(s)=255 final=1\");\n\t\t\t\n\t\timageCalculator(\"Add create\", \"Final_Result_W\",\"New\");\n\t\trename(\"sum_of_windows\");\n\t\n\t\timageCalculator(\"Multiply\", \"Final_Result_W_overlapping\",\"sum_of_windows\");\n\t\t// Devide the intersection by 2\t\t\t\t\n\t\trun(\"Calculator Plus\", \"i1=Final_Result_W_overlapping i2=Final_Result_W_overlapping operation=[Scale: i2 = i1 x k1 + k2] k1=0.5 k2=0\");\n\t\timageCalculator(\"Multiply\", \"Final_Result_W_non_overlapping\",\"sum_of_windows\");\t\t\t\t\n\t\n\t\timageCalculator(\"Add create\", \"Final_Result_W_overlapping\",\"Final_Result_W_non_overlapping\");\n\t\trename(\"sum_of_w\");\n\t\t\t\t\n\t\t// Insert it back\n\t\trun(\"Insert...\", \"source=sum_of_w destination=[Final_Result] x=\"+x+\" y=\"+y+\"\");\n\t\n        close(\"BF_Mask_W\");\n        close(\"BF_W\");\n\t\tclose(\"New\");\n\t\tclose(\"Final_Result_W\");\n\t\tclose(\"Final_Result_W_overlapping\");\n\t\tclose(\"Final_Result_W_non_overlapping\");\n\t\tclose(\"sum_of_windows\");\n\t\tclose(\"sum_of_w\");\n\t\tclose(\"Results\");\n\t\n\t}\n}\n\n// Round the pixel values\nselectWindow(\"Final_Result\");\nwidth=getWidth();\nheight=getHeight();\nfor (row=0; row<height; row++) {\n    for (col=0; col<width; col++) {\n    \tv = getPixel(col, row);         \n        if (isNaN(v)==false) {\n\t\t\tsetPixel(col, row, round(v));\n        }\n     }\n}\n\nselectWindow(\"Final_Result\");\nrun(\"Select None\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\n\nsetBatchMode(\"show\");\nrename(\"Membrane\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
