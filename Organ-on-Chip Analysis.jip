      "361fee85-04b1-467c-8c5f-23ecbba9bce1" : {
        "jipipe:graph-compartment" : "169aeb15-2bbc-44e4-95be-840f58c5343d",
        "jipipe:alias-id" : "epithelial-tissue-position",
        "jipipe:slot-configuration" : {
          "input" : {
            "Nuclei segmentation" : {
              "slot-data-type" : "imagej-imgplus-3d-greyscale-8u",
              "slot-type" : "Input",
              "name" : "Nuclei segmentation",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          },
          "output" : {
            "Epithelial tissue" : {
              "slot-data-type" : "imagej-imgplus-2d-greyscale-32f",
              "slot-type" : "Output",
              "name" : "Epithelial tissue",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "169aeb15-2bbc-44e4-95be-840f58c5343d" : {
            "VerticalCompact" : {
              "x" : 21,
              "y" : 17
            }
          }
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "setBatchMode(\"true\");\nsetBatchMode(\"hide\");\nsetOption(\"BlackBackground\", true);\n\n// Resolution\nselectWindow(\"Nuclei segmentation\");\nstrInfo=getImageInfo;\narrInfo=split(strInfo, \"\\n\");\narrInfo_resolution=Array.filter(arrInfo, \"Voxel size\");\nspl = split(arrInfo_resolution[0],\" \");\nResXYZ = split(spl[2],\"x\")\nResXY=ResXYZ[0];\nResZ=ResXYZ[2];\n\n// Image size\nselectWindow(\"Nuclei segmentation\");\nw = getWidth();\nh = getHeight();\nd=nSlices();\n\t\n// Create blank image for the final results\nnewImage(\"Final_Result_Surface\", \"8-bit\", w, h, 1);\nStack.setXUnit(\"micron\");\nrun(\"Properties...\", \"pixel_width=\"+ResXY+\" pixel_height=\"+ResXY+\" voxel_depth=\"+ResZ+\"\");\nrun(\"Invert\");\n\t\nsetForegroundColor(0, 0, 0);\nfor (j=1;j<=d;j++){\n    selectWindow(\"Nuclei segmentation\");\n    setSlice(j);\n    run(\"Duplicate...\", \"title=Slice_j\");\n\t\t\n\tselectWindow(\"Final_Result_Surface\");\n\trun(\"Duplicate...\", \"title=Final_Result_Overlap\");\n\tsetThreshold(1, 255);\n\trun(\"Convert to Mask\", \"method=Default background=Dark black\");\n\t\t\n\tselectWindow(\"Slice_j\");\n\timageCalculator(\"Subtract\", \"Slice_j\",\"Final_Result_Overlap\");\n\t\n\trun(\"Replace value\", \"pattern=255 replacement=\"+j+\"\");\n\timageCalculator(\"Add\", \"Final_Result_Surface\",\"Slice_j\");\n\t\n\tclose(\"Slice_j\");\n\tclose(\"Final_Result_Overlap\");\n\t\n}\n\t\nselectWindow(\"Final_Result_Surface\");\nrun(\"Duplicate...\", \"title=NaN\");\nrun(\"32-bit\");\ncall(\"ij.plugin.frame.ThresholdAdjuster.setMode\", \"Over/Under\");\nsetThreshold(1.0000, 1.000E+30);\nrun(\"NaN Background\");\nrun(\"Fire\");\nrun(\"Enhance Contrast\", \"saturated=0.35\");\n\nclose(\"\\\\Others\");\nclose(\"Results\");\nclose(\"Log\");\n\nsetBatchMode(\"show\");\nrename(\"Epithelial tissue\");",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Epithelial tissue position",
